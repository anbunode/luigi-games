# Copia a .env.deploy.local (no se sube a git) y rellena tus claves.
# Render: Account Settings -> API Keys
RENDER_API_KEY=rnd_tu_clave_aqui
# Opcional si ya conoces el ID (srv-...)
# RENDER_SERVICE_ID=
RENDER_SERVICE_NAME=skrepayshop-api

# Netlify: User settings -> Applications -> Personal access tokens
NETLIFY_AUTH_TOKEN=
# Opcional: Site configuration -> Site details -> Site ID
# NETLIFY_SITE_ID=
