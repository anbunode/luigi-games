# SkrepayShop API — variables de producción (Render)
# Pegar DATABASE_URL desde Supabase (misma instancia que ya usas)

NODE_ENV=production
HOST=0.0.0.0
NODE_VERSION=20

# Supabase (obligatorio — copiar desde dashboard Supabase → Connection string)
DATABASE_URL=

# Registro de plataforma Skrepay (tenants, dominios, OTP). Usualmente la misma URL que DATABASE_URL.
PLATFORM_DATABASE_URL=

# Desactivar provisión automática de schema en signup
# TENANT_AUTO_PROVISION=false

# URLs públicas SkrepayShop
MEDUSA_BACKEND_URL=https://api.skrepay.com
PLATFORM_URL=https://skrepay.com
STOREFRONT_URL=https://skrepay.com

# Correo transaccional (Resend — https://resend.com)
RESEND_API_KEY=
SKREPAY_EMAIL_FROM=SkrepayShop <noreply@skrepay.com>

# CORS (incluye URL Render activa)
STORE_CORS=https://skrepay.com,https://www.skrepay.com,https://app.skrepay.com
ADMIN_CORS=https://skrepay.com,https://www.skrepay.com,https://app.skrepay.com,https://skrepayshop-api.onrender.com
AUTH_CORS=https://skrepay.com,https://www.skrepay.com,https://app.skrepay.com,https://skrepayshop-api.onrender.com

# Generar en Render o usar valores seguros únicos
JWT_SECRET=
COOKIE_SECRET=
AUTH_MFA_ENCRYPTION_KEY=
