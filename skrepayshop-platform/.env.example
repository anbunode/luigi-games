# SkrepayShop — variables para Netlify (cuenta principal)
# Copia estas variables en Site settings → Environment variables

# Marca y URLs públicas (lo que ve el usuario)
NEXT_PUBLIC_PLATFORM_NAME=SkrepayShop
NEXT_PUBLIC_PLATFORM_URL=https://skrepay.com
NEXT_PUBLIC_PANEL_URL=https://app.skrepay.com

# API Medusa en Render (obligatorio hasta tener api.skrepay.com con DNS)
# Sustituye por tu URL Render activa o por https://api.skrepay.com cuando el CNAME esté listo
MEDUSA_BACKEND_URL=https://TU-SERVICIO.onrender.com
NEXT_PUBLIC_ADMIN_ORIGIN=https://TU-SERVICIO.onrender.com

# Futuro multi-tenant
NEXT_PUBLIC_TENANT_STORE_BASE=skrepay.shop
NEXT_PUBLIC_PAYMENT_LINK_BASE=pay.skrepay.com
NEXT_PUBLIC_DEMO_STORE_URL=https://demo.skrepay.shop
